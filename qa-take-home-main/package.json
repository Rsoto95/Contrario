{
  "name": "ats-submit-candidate-mimic",
  "version": "1.0.0",
  "description": "QA take-home: a NestJS + Prisma mimic of the ATS submit-candidate flow",
  "license": "UNLICENSED",
  "scripts": {
    "postinstall": "prisma generate",
    "setup": "npm install && npm run db:reset",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "seed": "ts-node prisma/seed.ts",
    "db:push": "prisma db push --force-reset --skip-generate",
    "db:reset": "prisma db push --force-reset --skip-generate && npm run seed"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@prisma/client": "^5.19.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.4",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.19.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
}
