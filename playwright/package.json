{
  "name": "contrario-playwright-automation",
  "version": "1.0.0",
  "description": "Playwright E2E automation for Contrario",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "report": "monocart show-report monocart-report/index.html",
    "report:html": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "monocart-reporter": "^2.12.2"
  }
}
